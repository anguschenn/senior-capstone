# ---------------------------------------------------------------
# Plaid API  —  dashboard.plaid.com → Team → Keys
# ---------------------------------------------------------------
PLAID_CLIENT_ID=
PLAID_SECRET=

# sandbox | development | production
# Trial plan: use "sandbox" env with sandbox secret for fake data,
# or switch PLAID_ENV to "development" + use your development secret
# for real live connections (up to 100 items on development).
PLAID_ENV=sandbox

# Comma-separated list of Plaid products to request.
# Only request what you actually use — extra products increase
# the approval surface when moving to production.
# Options: transactions, auth, identity, investments, liabilities
PLAID_PRODUCTS=transactions,auth

# Comma-separated ISO country codes.
PLAID_COUNTRY_CODES=US

# Required for OAuth banks (Chase, Wells Fargo, etc.) even in sandbox.
# Register this URI at dashboard.plaid.com → Team → API.
# Local dev: http://localhost:3000/oauth-return
# Production: must be https://
PLAID_REDIRECT_URI=

# ---------------------------------------------------------------
# Supabase  —  supabase dashboard → Settings → API
# ---------------------------------------------------------------
SUPABASE_URL=
# service_role key — backend only, NEVER expose to Flutter/browser
SUPABASE_KEY=
# JWT Secret — Settings → API → JWT Secret
# Used to validate Supabase Auth tokens sent from Flutter
SUPABASE_JWT_SECRET=

# ---------------------------------------------------------------
# AI layer  —  console.ai.google.dev
# ---------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ---------------------------------------------------------------
# Server
# ---------------------------------------------------------------
PORT=8000
FLASK_DEBUG=false

# Comma-separated origins allowed to call this backend.
# Dev: http://localhost:3000,http://localhost:8080
# Production: https://yourapp.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
